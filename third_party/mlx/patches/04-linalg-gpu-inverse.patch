+void Inverse::eval_gpu(const std::vector<array>& inputs, array& output) {
+  const auto& a = inputs[0];
+
+  if (a.dtype() != float32) {
+    throw std::runtime_error(
+        "[Inverse::eval_gpu] Only float32 is supported.");
+  }
+
+  int N = a.shape(-1);
+  if (N == 0) {
+    output.set_data(allocator::malloc(0));
+    return;
+  }
+
+  size_t num_matrices = a.size() / (N * N);
+  size_t elem_size = size_of(a.dtype());
+
+  if (tri_) {
+    throw std::runtime_error(
+        "[Inverse::eval_gpu] Triangular inverse NYI on Metal.");
+  }
+
+  // General inverse: A^{-1} via LU factorization + LU solve.
+  //   1. Copy A into a temporary and LU-factor it in-place.
+  //   2. Solve LU * X = I  =>  X = A^{-1}.
+
+  // Temporary for the LU-factored matrix.
+  array lu_temp(a.shape(), a.dtype(), nullptr, {});
+  copy_gpu(
+      a,
+      lu_temp,
+      a.flags().row_contiguous ? CopyType::Vector : CopyType::General);
+
+  // Temporary for pivot indices (N per matrix for square matrices).
+  Shape piv_shape(a.shape().begin(), a.shape().end() - 1);
+  array piv_temp(piv_shape, uint32, nullptr, {});
+  piv_temp.set_data(allocator::malloc(piv_temp.nbytes()));
+
+  // Temporary identity matrix (RHS for the solve).
+  array identity_temp(a.shape(), a.dtype(), nullptr, {});
+  identity_temp.set_data(allocator::malloc(identity_temp.nbytes()));
+  auto* id_ptr = identity_temp.data<float>();
+  std::memset(id_ptr, 0, identity_temp.nbytes());
+  for (size_t i = 0; i < num_matrices; i++) {
+    for (int j = 0; j < N; j++) {
+      id_ptr[i * N * N + j * N + j] = 1.0f;
+    }
+  }
+
+  // Allocate output.
+  output.set_data(allocator::malloc(output.nbytes()));
+
+  auto& s = stream();
+  auto& d = metal::device(s.device);
+
+  d.end_encoding(s.index);
+  auto* cb = d.get_command_buffer(s.index);
+  id<MTLCommandBuffer> cmd_buf =
+      (__bridge id<MTLCommandBuffer>)cb;
+  id<MTLDevice> mtl_dev =
+      (__bridge id<MTLDevice>)d.mtl_device();
+
+  id<MTLBuffer> lu_buf =
+      (__bridge id<MTLBuffer>)(const_cast<void*>(lu_temp.buffer().ptr()));
+  id<MTLBuffer> piv_buf =
+      (__bridge id<MTLBuffer>)(const_cast<void*>(piv_temp.buffer().ptr()));
+  id<MTLBuffer> id_buf =
+      (__bridge id<MTLBuffer>)(const_cast<void*>(
+          identity_temp.buffer().ptr()));
+  id<MTLBuffer> out_buf =
+      (__bridge id<MTLBuffer>)(const_cast<void*>(output.buffer().ptr()));
+
+  for (size_t i = 0; i < num_matrices; i++) {
+    size_t mat_byte_offset = i * N * N * elem_size;
+    size_t piv_byte_offset = i * N * sizeof(uint32_t);
+
+    MPSMatrixDescriptor* mat_desc = [MPSMatrixDescriptor
+        matrixDescriptorWithRows:(NSUInteger)N
+                         columns:(NSUInteger)N
+                        rowBytes:(NSUInteger)(N * elem_size)
+                        dataType:MPSDataTypeFloat32];
+
+    MPSMatrixDescriptor* piv_desc = [MPSMatrixDescriptor
+        matrixDescriptorWithRows:1
+                         columns:(NSUInteger)N
+                        rowBytes:(NSUInteger)(N * sizeof(uint32_t))
+                        dataType:MPSDataTypeUInt32];
+
+    // Step 1: LU factorization in-place on lu_temp.
+    MPSMatrix* lu_src = [[MPSMatrix alloc] initWithBuffer:lu_buf
+                                                   offset:mat_byte_offset
+                                               descriptor:mat_desc];
+    MPSMatrix* lu_dst = [[MPSMatrix alloc] initWithBuffer:lu_buf
+                                                   offset:mat_byte_offset
+                                               descriptor:mat_desc];
+    MPSMatrix* piv_mat = [[MPSMatrix alloc] initWithBuffer:piv_buf
+                                                    offset:piv_byte_offset
+                                                descriptor:piv_desc];
+
+    MPSMatrixDecompositionLU* lu_kernel =
+        [[MPSMatrixDecompositionLU alloc] initWithDevice:mtl_dev
+                                                    rows:(NSUInteger)N
+                                                 columns:(NSUInteger)N];
+    [lu_kernel encodeToCommandBuffer:cmd_buf
+                        sourceMatrix:lu_src
+                        resultMatrix:lu_dst
+                        pivotIndices:piv_mat
+                              status:nil];
+
+    // Step 2: Solve LU * X = I, writing X = A^{-1} to output.
+    MPSMatrix* rhs_mat = [[MPSMatrix alloc] initWithBuffer:id_buf
+                                                    offset:mat_byte_offset
+                                                descriptor:mat_desc];
+    MPSMatrix* sol_mat = [[MPSMatrix alloc] initWithBuffer:out_buf
+                                                    offset:mat_byte_offset
+                                                descriptor:mat_desc];
+
+    MPSMatrixSolveLU* solve_kernel =
+        [[MPSMatrixSolveLU alloc] initWithDevice:mtl_dev
+                                       transpose:NO
+                                           order:(NSUInteger)N
+                          numberOfRightHandSides:(NSUInteger)N];
+    [solve_kernel encodeToCommandBuffer:cmd_buf
+                           sourceMatrix:lu_dst
+                    rightHandSideMatrix:rhs_mat
+                           pivotIndices:piv_mat
+                         solutionMatrix:sol_mat];
+  }
+
+  // Keep temporaries alive until GPU work completes.
+  d.add_temporary(std::move(lu_temp), s.index);
+  d.add_temporary(std::move(piv_temp), s.index);
+  d.add_temporary(std::move(identity_temp), s.index);
+}
+
 } // namespace mlx::core
