+void Eigh::eval_gpu(
+    const std::vector<array>& inputs,
+    std::vector<array>& outputs) {
+    const auto& a = inputs[0];
+
+    if (a.dtype() != float32) {
+        throw std::runtime_error(
+            "[Eigh::eval_gpu] Only float32 is supported on Metal.");
+    }
+
+    int N = a.shape(-1);
+    if (N == 0) {
+        for (auto& o : outputs) {
+            o.set_data(allocator::malloc(o.nbytes()));
+        }
+        return;
+    }
+    if (N > 63) {
+        throw std::runtime_error(
+            "[Eigh::eval_gpu] Metal Eigh currently supports matrices up to "
+            "63×63. Got " + std::to_string(N) + "×" + std::to_string(N) + ".");
+    }
+
+    size_t num_matrices = a.size() / (N * N);
+
+    auto& values = outputs[0];
+    values.set_data(allocator::malloc(values.nbytes()));
+
+    // If computing eigenvectors, output[1] holds them; otherwise we still
+    // need a temporary for the kernel (which reads A through the eigenvector
+    // buffer path).
+    array vectors = compute_eigenvectors_
+        ? outputs[1]
+        : array(a.shape(), a.dtype(), nullptr, {});
+    if (compute_eigenvectors_) {
+        vectors.set_data(allocator::malloc(vectors.nbytes()));
+    } else {
+        vectors.set_data(allocator::malloc(a.nbytes()));
+    }
+
+    // Ensure input is row-contiguous.
+    array a_contig = ensure_row_contiguous(a);
+
+    auto& s = stream();
+    auto& d = metal::device(s.device);
+
+    id<MTLDevice> mtl_dev = (__bridge id<MTLDevice>)d.mtl_device();
+    id<MTLComputePipelineState> pso = getEighPipeline(mtl_dev);
+
+    // Params buffer: {N, max_sweeps, compute_eigenvectors, 0}
+    uint32_t max_sweeps = (N <= 8) ? 30 : (N <= 16 ? 50 : 100);
+    uint32_t params[4] = {
+        static_cast<uint32_t>(N),
+        max_sweeps,
+        compute_eigenvectors_ ? 1u : 0u,
+        0u
+    };
+    float tol = 1e-7f;
+
+    // Use MLX's managed compute encoder (ensures proper ordering with
+    // prior work that produced the input arrays).
+    auto& compute_encoder = d.get_command_encoder(s.index);
+    compute_encoder.set_compute_pipeline_state((__bridge MTL::ComputePipelineState*)pso);
+    compute_encoder.set_input_array(a_contig, 0);
+    compute_encoder.set_output_array(values, 1);
+    compute_encoder.set_output_array(vectors, 2);
+    compute_encoder.set_bytes(params, sizeof(params), 3);
+    compute_encoder.set_bytes(&tol, sizeof(tol), 4);
+
+    NSUInteger tg_size = std::min(
+        static_cast<NSUInteger>(256),
+        [pso maxTotalThreadsPerThreadgroup]);
+    compute_encoder.dispatch_threadgroups(
+        MTL::Size(num_matrices, 1, 1),
+        MTL::Size(tg_size, 1, 1));
+
+    // Sorting is done in the Metal kernel (in shared memory before writing).
+
+    if (!compute_eigenvectors_) {
+        d.add_temporary(std::move(vectors), s.index);
+    }
+    d.add_temporary(std::move(a_contig), s.index);
+}
