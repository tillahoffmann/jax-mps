+// ---------------------------------------------------------------------------
+// QRF – Modified Gram-Schmidt QR decomposition on GPU via Metal compute.
+//
+// For matrices up to 32×32 we run a monolithic kernel in threadgroup shared
+// memory.  Larger matrices currently throw.
+// ---------------------------------------------------------------------------
+
+namespace /* anonymous – QR helpers */ {
+
+static NSString* const kQRKernelSource = @R"(
+#include <metal_stdlib>
+using namespace metal;
+
+// Modified Gram-Schmidt QR for float32 matrices up to 32×32.
+// One threadgroup per matrix.
+//
+// Buffers:
+//   0 – input  A  (batch × M × N, row-major)
+//   1 – output Q  (batch × M × K, row-major)   K = min(M,N)
+//   2 – output R  (batch × K × N, row-major)
+//   3 – params: uint4(M, N, K, 0)
+//
+// Grid: (batch,1,1) threadgroups of (256,1,1).
+
+kernel void qr_mgs(
+    device const float* A_in  [[buffer(0)]],
+    device float*       Q_out [[buffer(1)]],
+    device float*       R_out [[buffer(2)]],
+    device const uint*  params [[buffer(3)]],
+    uint tid   [[thread_index_in_threadgroup]],
+    uint tg_sz [[threads_per_threadgroup]],
+    uint batch [[threadgroup_position_in_grid]])
+{
+    const uint M = params[0];
+    const uint N = params[1];
+    const uint K = params[2]; // min(M,N)
+
+    // Shared memory: working copy of A (M×N) used in-place.
+    threadgroup float W[64 * 64];  // max 64×64
+    // Shared reduction buffer.
+    threadgroup float red[256];
+
+    const uint MN = M * N;
+    device const float* A_batch = A_in + batch * MN;
+    device float* Q_batch = Q_out + batch * M * K;
+    device float* R_batch = R_out + batch * K * N;
+
+    // Load A into shared memory.
+    for (uint idx = tid; idx < MN; idx += tg_sz) {
+        W[idx] = A_batch[idx];
+    }
+    threadgroup_barrier(mem_flags::mem_threadgroup);
+
+    // Zero R output (only the part this kernel touches).
+    for (uint idx = tid; idx < K * N; idx += tg_sz) {
+        R_batch[idx] = 0.0f;
+    }
+
+    for (uint j = 0; j < K; j++) {
+        // --- Compute norm of column j of W ---
+        float local_sum = 0.0f;
+        for (uint i = tid; i < M; i += tg_sz) {
+            float v = W[i * N + j];
+            local_sum += v * v;
+        }
+        red[tid] = local_sum;
+        threadgroup_barrier(mem_flags::mem_threadgroup);
+
+        // Tree reduction.
+        for (uint stride = tg_sz / 2; stride > 0; stride /= 2) {
+            if (tid < stride) red[tid] += red[tid + stride];
+            threadgroup_barrier(mem_flags::mem_threadgroup);
+        }
+        float norm = metal::sqrt(red[0]);
+
+        // R[j,j] = norm.
+        if (tid == 0) {
+            R_batch[j * N + j] = norm;
+        }
+
+        // Normalise column j → Q column j, stored in W[:,j].
+        float inv_norm = (norm > 1e-30f) ? 1.0f / norm : 0.0f;
+        for (uint i = tid; i < M; i += tg_sz) {
+            W[i * N + j] *= inv_norm;
+        }
+        threadgroup_barrier(mem_flags::mem_threadgroup);
+
+        // --- Orthogonalise subsequent columns against column j ---
+        for (uint k = j + 1; k < N; k++) {
+            // Dot product: Q[:,j]^T * W[:,k]
+            float local_dot = 0.0f;
+            for (uint i = tid; i < M; i += tg_sz) {
+                local_dot += W[i * N + j] * W[i * N + k];
+            }
+            red[tid] = local_dot;
+            threadgroup_barrier(mem_flags::mem_threadgroup);
+
+            for (uint stride = tg_sz / 2; stride > 0; stride /= 2) {
+                if (tid < stride) red[tid] += red[tid + stride];
+                threadgroup_barrier(mem_flags::mem_threadgroup);
+            }
+            float dot = red[0];
+
+            // R[j,k] = dot.
+            if (tid == 0) {
+                R_batch[j * N + k] = dot;
+            }
+
+            // W[:,k] -= dot * W[:,j]
+            for (uint i = tid; i < M; i += tg_sz) {
+                W[i * N + k] -= dot * W[i * N + j];
+            }
+            threadgroup_barrier(mem_flags::mem_threadgroup);
+        }
+    }
+
+    // --- Write Q from W columns 0..K-1 ---
+    for (uint i = tid; i < M * K; i += tg_sz) {
+        uint r = i / K;
+        uint c = i % K;
+        Q_batch[i] = W[r * N + c];
+    }
+}
+)";
+
+static id<MTLComputePipelineState> getQRPipeline(id<MTLDevice> device) {
+    static dispatch_once_t once;
+    static id<MTLComputePipelineState> pso;
+    dispatch_once(&once, ^{
+        pso = compilePipeline(device, kQRKernelSource,
+                              @"qr_mgs", "[QRF::eval_gpu]");
+    });
+    return pso;
+}
