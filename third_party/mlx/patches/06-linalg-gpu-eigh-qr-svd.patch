+// ---------------------------------------------------------------------------
+// Eigh – Jacobi eigenvalue decomposition on GPU via Metal compute kernel.
+//
+// For matrices up to 32×32 we run a monolithic kernel entirely in threadgroup
+// shared memory.  Larger matrices fall back to the CPU implementation.
+// ---------------------------------------------------------------------------
+
+namespace /* anonymous – Eigh helpers */ {
+
+// Metal shader source compiled once at first use.
+static NSString* const kEighKernelSource = @R"(
+#include <metal_stdlib>
+using namespace metal;
+
+// Jacobi eigenvalue for symmetric float32 matrices up to 32×32.
+// One threadgroup per matrix.  All work in shared memory.
+//
+// Buffers:
+//   0  – input  A   (batch × N × N, row-major, only lower/upper used)
+//   1  – output eigenvalues  (batch × N)
+//   2  – output eigenvectors (batch × N × N, row-major)
+//   3  – params: uint4(N, max_sweeps, compute_eigenvectors, 0)
+//   4  – tolerance (float)
+//
+// Grid:  (batch, 1, 1)  threadgroups of (256, 1, 1).
+
+kernel void eigh_jacobi(
+    device const float* A_in           [[buffer(0)]],
+    device float*       eigenvalues    [[buffer(1)]],
+    device float*       eigenvectors   [[buffer(2)]],
+    device const uint*  params         [[buffer(3)]],
+    device const float* tol_buf        [[buffer(4)]],
+    uint  tid   [[thread_index_in_threadgroup]],
+    uint  tg_sz [[threads_per_threadgroup]],
+    uint  batch [[threadgroup_position_in_grid]])
+{
+    const uint N           = params[0];
+    const uint max_sweeps  = params[1];
+    const uint compute_ev  = params[2];
+    const float tol        = tol_buf[0];
+
+    // Shared memory – two N×N matrices plus 2 shared scalars (g_c, g_s).
+    // Max N = 63 → 63*63*4*2 + 8 = 31,760 bytes (< 32KB limit).
+    threadgroup float S[63 * 63];  // working copy of A (symmetrised)
+    threadgroup float V[63 * 63];  // eigenvector accumulator
+
+    const uint NN = N * N;
+    device const float* A_batch = A_in + batch * NN;
+
+    // Load A into shared memory (full symmetric copy) and V = I.
+    for (uint idx = tid; idx < NN; idx += tg_sz) {
+        uint r = idx / N, c = idx % N;
+        // Always symmetrise: take lower triangle from input.
+        float val = (r >= c) ? A_batch[r * N + c] : A_batch[c * N + r];
+        S[idx] = val;
+        V[idx] = (r == c) ? 1.0f : 0.0f;
+    }
+    threadgroup_barrier(mem_flags::mem_threadgroup);
+
+    // Shared scalars written by thread 0, read by all.
+    threadgroup float g_c;
+    threadgroup float g_s;
+
+    for (uint sweep = 0; sweep < max_sweeps; sweep++) {
+        bool any_rotated = false;
+
+        // Cyclic sweep over all (p,q) pairs with p < q.
+        for (uint p = 0; p < N - 1; p++) {
+            for (uint q = p + 1; q < N; q++) {
+                threadgroup_barrier(mem_flags::mem_threadgroup);
+
+                // Thread 0 computes the rotation for this pair.
+                if (tid == 0) {
+                    float Apq = S[p * N + q];
+                    float App = S[p * N + p];
+                    float Aqq = S[q * N + q];
+
+                    g_c = 1.0f;
+                    g_s = 0.0f;
+
+                    if (metal::abs(Apq) > tol) {
+                        float tau = (Aqq - App) / (2.0f * Apq);
+                        float t;
+                        if (tau >= 0.0f)
+                            t = 1.0f / ( tau + metal::sqrt(1.0f + tau * tau));
+                        else
+                            t = 1.0f / ( tau - metal::sqrt(1.0f + tau * tau));
+                        g_c = 1.0f / metal::sqrt(1.0f + t * t);
+                        g_s = t * g_c;
+                    }
+                }
+                threadgroup_barrier(mem_flags::mem_threadgroup);
+
+                float c = g_c;
+                float s = g_s;
+                if (s == 0.0f) continue;  // no rotation needed
+                any_rotated = true;
+
+                // --- Apply rotation to columns p, q of S (symmetric update) ---
+                // Each thread handles a subset of rows.
+                for (uint i = tid; i < N; i += tg_sz) {
+                    float sip = S[i * N + p];
+                    float siq = S[i * N + q];
+                    float np = c * sip - s * siq;
+                    float nq = s * sip + c * siq;
+                    S[i * N + p] = np;
+                    S[i * N + q] = nq;
+                }
+                threadgroup_barrier(mem_flags::mem_threadgroup);
+
+                // Apply rotation to rows p, q of S.
+                for (uint j = tid; j < N; j += tg_sz) {
+                    float spj = S[p * N + j];
+                    float sqj = S[q * N + j];
+                    float np = c * spj - s * sqj;
+                    float nq = s * spj + c * sqj;
+                    S[p * N + j] = np;
+                    S[q * N + j] = nq;
+                }
+                threadgroup_barrier(mem_flags::mem_threadgroup);
+
+                // Force A[p][q] = A[q][p] = 0 (numerical hygiene).
+                if (tid == 0) {
+                    S[p * N + q] = 0.0f;
+                    S[q * N + p] = 0.0f;
+                }
+
+                // Update eigenvector matrix V: columns p, q.
+                if (compute_ev) {
+                    for (uint i = tid; i < N; i += tg_sz) {
+                        float vip = V[i * N + p];
+                        float viq = V[i * N + q];
+                        V[i * N + p] = c * vip - s * viq;
+                        V[i * N + q] = s * vip + c * viq;
+                    }
+                }
+                threadgroup_barrier(mem_flags::mem_threadgroup);
+            } // q
+        } // p
+
+        if (!any_rotated) break;  // converged
+    } // sweep
+
+    // --- Sort eigenvalues ascending (and permute eigenvector columns) ---
+    if (tid == 0) {
+        for (uint i = 0; i < N - 1; i++) {
+            uint min_idx = i;
+            for (uint j = i + 1; j < N; j++) {
+                if (S[j * N + j] < S[min_idx * N + min_idx]) min_idx = j;
+            }
+            if (min_idx != i) {
+                float tmp = S[i * N + i];
+                S[i * N + i] = S[min_idx * N + min_idx];
+                S[min_idx * N + min_idx] = tmp;
+                if (compute_ev) {
+                    for (uint r = 0; r < N; r++) {
+                        float vt = V[r * N + i];
+                        V[r * N + i] = V[r * N + min_idx];
+                        V[r * N + min_idx] = vt;
+                    }
+                }
+            }
+        }
+    }
+    threadgroup_barrier(mem_flags::mem_threadgroup);
+
+    // --- Write eigenvalues (diagonal of S) ---
+    device float* eval_batch = eigenvalues + batch * N;
+    for (uint i = tid; i < N; i += tg_sz) {
+        eval_batch[i] = S[i * N + i];
+    }
+
+    // --- Write eigenvectors ---
+    if (compute_ev) {
+        device float* evec_batch = eigenvectors + batch * NN;
+        for (uint idx = tid; idx < NN; idx += tg_sz) {
+            evec_batch[idx] = V[idx];
+        }
+    }
+}
+)";
+
+static id<MTLComputePipelineState> compilePipeline(
+    id<MTLDevice> device, NSString* source, NSString* funcName,
+    const char* label) {
+    @autoreleasepool {
+        NSError* error = nil;
+        MTLCompileOptions* opts = [[MTLCompileOptions alloc] init];
+        opts.fastMathEnabled = YES;
+        id<MTLLibrary> lib = [device newLibraryWithSource:source
+                                                  options:opts
+                                                    error:&error];
+        if (!lib) {
+            throw std::runtime_error(
+                std::string(label) + " Failed to compile Metal kernel: " +
+                [[error localizedDescription] UTF8String]);
+        }
+        id<MTLFunction> func = [lib newFunctionWithName:funcName];
+        if (!func) {
+            throw std::runtime_error(
+                std::string(label) + " Kernel function not found");
+        }
+        id<MTLComputePipelineState> pso =
+            [device newComputePipelineStateWithFunction:func error:&error];
+        if (!pso) {
+            throw std::runtime_error(
+                std::string(label) + " Failed to create pipeline: " +
+                [[error localizedDescription] UTF8String]);
+        }
+        return pso;
+    }
+}
+
+static id<MTLComputePipelineState> getEighPipeline(id<MTLDevice> device) {
+    static dispatch_once_t once;
+    static id<MTLComputePipelineState> pso;
+    dispatch_once(&once, ^{
+        pso = compilePipeline(device, kEighKernelSource,
+                              @"eigh_jacobi", "[Eigh::eval_gpu]");
+    });
+    return pso;
+}
+
