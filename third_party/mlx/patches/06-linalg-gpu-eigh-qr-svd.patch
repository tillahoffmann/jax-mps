+// ---------------------------------------------------------------------------
+// SVD – One-sided Jacobi SVD on GPU via Metal compute kernel.
+//
+// Computes A^T*A, diagonalises it with Jacobi rotations to get V and σ²,
+// then U = A·V·Σ⁻¹.  Matrices up to 32×32.
+// ---------------------------------------------------------------------------
+
+namespace /* anonymous – SVD helpers */ {
+
+static NSString* const kSVDKernelSource = @R"(
+#include <metal_stdlib>
+using namespace metal;
+
+// One-sided Jacobi SVD for float32 matrices up to 32×32.
+// One threadgroup per matrix.
+//
+// Buffers:
+//   0  – input  A   (batch × M × N, row-major)
+//   1  – output U   (batch × M × M, row-major) [if compute_uv]
+//   2  – output S   (batch × K)                 K = min(M,N)
+//   3  – output Vt  (batch × N × N, row-major) [if compute_uv]
+//   4  – params: uint4(M, N, K, compute_uv)
+//   5  – tolerance (float)
+//   6  – max_sweeps (uint)
+//
+// Grid: (batch,1,1)  threadgroups of (256,1,1).
+
+kernel void svd_jacobi(
+    device const float* A_in   [[buffer(0)]],
+    device float*       U_out  [[buffer(1)]],
+    device float*       S_out  [[buffer(2)]],
+    device float*       Vt_out [[buffer(3)]],
+    device const uint*  params [[buffer(4)]],
+    device const float* tol_buf [[buffer(5)]],
+    device const uint*  sweep_buf [[buffer(6)]],
+    uint tid   [[thread_index_in_threadgroup]],
+    uint tg_sz [[threads_per_threadgroup]],
+    uint batch [[threadgroup_position_in_grid]])
+{
+    const uint M = params[0];
+    const uint N = params[1];
+    const uint K = params[2];
+    const uint compute_uv = params[3];
+    const float tol = tol_buf[0];
+    const uint max_sweeps = sweep_buf[0];
+
+    // Shared memory pools.
+    threadgroup float A_sh[51 * 51];   // copy of A (M×N)
+    threadgroup float G[51 * 51];      // A^T*A (N×N)
+    threadgroup float V[51 * 51];      // eigenvectors of G (N×N)
+
+    const uint MN = M * N;
+    const uint NN = N * N;
+    device const float* A_batch = A_in + batch * MN;
+
+    // Load A into shared memory.
+    for (uint idx = tid; idx < MN; idx += tg_sz) {
+        A_sh[idx] = A_batch[idx];
+    }
+    threadgroup_barrier(mem_flags::mem_threadgroup);
+
+    // --- Step 1: Compute G = A^T * A in shared memory ---
+    for (uint idx = tid; idx < NN; idx += tg_sz) {
+        uint i = idx / N;
+        uint j = idx % N;
+        float sum = 0.0f;
+        for (uint k = 0; k < M; k++) {
+            sum += A_sh[k * N + i] * A_sh[k * N + j];
+        }
+        G[idx] = sum;
+        V[idx] = (i == j) ? 1.0f : 0.0f;
+    }
+    threadgroup_barrier(mem_flags::mem_threadgroup);
+
+    // --- Step 2: Jacobi eigenvalue iteration on G ---
+    threadgroup float g_c;
+    threadgroup float g_s;
+
+    for (uint sweep = 0; sweep < max_sweeps; sweep++) {
+        bool any_rotated = false;
+        for (uint p = 0; p < N - 1; p++) {
+            for (uint q = p + 1; q < N; q++) {
+                threadgroup_barrier(mem_flags::mem_threadgroup);
+
+                if (tid == 0) {
+                    float Gpq = G[p * N + q];
+                    float Gpp = G[p * N + p];
+                    float Gqq = G[q * N + q];
+                    g_c = 1.0f;
+                    g_s = 0.0f;
+                    if (metal::abs(Gpq) > tol) {
+                        float tau = (Gqq - Gpp) / (2.0f * Gpq);
+                        float t;
+                        if (tau >= 0.0f)
+                            t = 1.0f / (tau + metal::sqrt(1.0f + tau * tau));
+                        else
+                            t = 1.0f / (tau - metal::sqrt(1.0f + tau * tau));
+                        g_c = 1.0f / metal::sqrt(1.0f + t * t);
+                        g_s = t * g_c;
+                    }
+                }
+                threadgroup_barrier(mem_flags::mem_threadgroup);
+
+                float c = g_c, s = g_s;
+                if (s == 0.0f) continue;
+                any_rotated = true;
+
+                for (uint i = tid; i < N; i += tg_sz) {
+                    float gip = G[i * N + p], giq = G[i * N + q];
+                    G[i * N + p] = c * gip - s * giq;
+                    G[i * N + q] = s * gip + c * giq;
+                }
+                threadgroup_barrier(mem_flags::mem_threadgroup);
+                for (uint j = tid; j < N; j += tg_sz) {
+                    float gpj = G[p * N + j], gqj = G[q * N + j];
+                    G[p * N + j] = c * gpj - s * gqj;
+                    G[q * N + j] = s * gpj + c * gqj;
+                }
+                threadgroup_barrier(mem_flags::mem_threadgroup);
+                if (tid == 0) {
+                    G[p * N + q] = 0.0f;
+                    G[q * N + p] = 0.0f;
+                }
+                for (uint i = tid; i < N; i += tg_sz) {
+                    float vip = V[i * N + p], viq = V[i * N + q];
+                    V[i * N + p] = c * vip - s * viq;
+                    V[i * N + q] = s * vip + c * viq;
+                }
+                threadgroup_barrier(mem_flags::mem_threadgroup);
+            }
+        }
+        if (!any_rotated) break;
+    }
+
+    // --- Step 3: Extract singular values and sort descending in shared mem ---
+    for (uint i = tid; i < K; i += tg_sz) {
+        float eigval = G[i * N + i];
+        G[i * N + i] = metal::sqrt(metal::max(eigval, 0.0f));
+    }
+    threadgroup_barrier(mem_flags::mem_threadgroup);
+
+    // Thread 0: selection sort descending.
+    if (tid == 0) {
+        for (uint i = 0; i < K - 1; i++) {
+            uint max_idx = i;
+            for (uint j = i + 1; j < K; j++) {
+                if (G[j * N + j] > G[max_idx * N + max_idx]) max_idx = j;
+            }
+            if (max_idx != i) {
+                float tmp = G[i * N + i];
+                G[i * N + i] = G[max_idx * N + max_idx];
+                G[max_idx * N + max_idx] = tmp;
+                for (uint r = 0; r < N; r++) {
+                    float vt = V[r * N + i];
+                    V[r * N + i] = V[r * N + max_idx];
+                    V[r * N + max_idx] = vt;
+                }
+            }
+        }
+    }
+    threadgroup_barrier(mem_flags::mem_threadgroup);
+
+    // Write S.
+    device float* S_batch = S_out + batch * K;
+    for (uint i = tid; i < K; i += tg_sz) {
+        S_batch[i] = G[i * N + i];
+    }
+
+    if (!compute_uv) return;
+
+    // --- Step 4: Write Vt (transpose of V) ---
+    device float* Vt_batch = Vt_out + batch * NN;
+    for (uint idx = tid; idx < NN; idx += tg_sz) {
+        uint i = idx / N, j = idx % N;
+        Vt_batch[idx] = V[j * N + i]; // transpose
+    }
+
+    // --- Step 5: Compute U = A * V * Σ^{-1} ---
+    // U is M×M.  We compute U[:,j] for j < K; fill rest with zeros.
+    device float* U_batch = U_out + batch * M * M;
+    for (uint idx = tid; idx < M * M; idx += tg_sz) {
+        uint i = idx / M;  // row of U
+        uint j = idx % M;  // col of U
+
+        if (j < K) {
+            float sigma = G[j * N + j]; // σ_j stored in diagonal
+            float inv_sigma = (sigma > 1e-10f) ? 1.0f / sigma : 0.0f;
+            float sum = 0.0f;
+            for (uint k = 0; k < N; k++) {
+                sum += A_sh[i * N + k] * V[k * N + j];
+            }
+            U_batch[idx] = sum * inv_sigma;
+        } else {
+            U_batch[idx] = (i == j) ? 1.0f : 0.0f;
+        }
+    }
+}
+)";
+
+static id<MTLComputePipelineState> getSVDPipeline(id<MTLDevice> device) {
+    static dispatch_once_t once;
+    static id<MTLComputePipelineState> pso;
+    dispatch_once(&once, ^{
+        pso = compilePipeline(device, kSVDKernelSource,
+                              @"svd_jacobi", "[SVD::eval_gpu]");
+    });
+    return pso;
+}
+
+} // anonymous namespace
+
+void SVD::eval_gpu(
+    const std::vector<array>& inputs,
+    std::vector<array>& outputs) {
+    const auto& a = inputs[0];
+
+    if (a.dtype() != float32) {
+        throw std::runtime_error(
+            "[SVD::eval_gpu] Only float32 is supported on Metal.");
+    }
+
+    int M = a.shape(-2);
+    int N = a.shape(-1);
+    int K = std::min(M, N);
+
+    if (M == 0 || N == 0) {
+        for (auto& o : outputs) {
+            o.set_data(allocator::malloc(o.nbytes()));
+        }
+        return;
+    }
+    if (M > 51 || N > 51) {
+        throw std::runtime_error(
+            "[SVD::eval_gpu] Metal SVD currently supports matrices up to "
+            "51×51. Got " + std::to_string(M) + "×" + std::to_string(N) + ".");
+    }
+
+    size_t num_matrices = a.size() / (M * N);
+
+    // Allocate outputs.
+    for (auto& o : outputs) {
+        o.set_data(allocator::malloc(o.nbytes()));
+    }
+
+    array a_contig = ensure_row_contiguous(a);
+
+    auto& s = stream();
+    auto& d = metal::device(s.device);
+
+    id<MTLDevice> mtl_dev = (__bridge id<MTLDevice>)d.mtl_device();
+    id<MTLComputePipelineState> pso = getSVDPipeline(mtl_dev);
+
+    uint32_t params[4] = {
+        static_cast<uint32_t>(M),
+        static_cast<uint32_t>(N),
+        static_cast<uint32_t>(K),
+        compute_uv_ ? 1u : 0u
+    };
+    float tol = 1e-7f;
+    uint32_t max_sweeps = (K <= 8) ? 30 : (K <= 16 ? 50 : 100);
+
+    auto& compute_encoder = d.get_command_encoder(s.index);
+    compute_encoder.set_compute_pipeline_state((__bridge MTL::ComputePipelineState*)pso);
+    compute_encoder.set_input_array(a_contig, 0);
+
+    if (compute_uv_) {
+        compute_encoder.set_output_array(outputs[0], 1); // U
+        compute_encoder.set_output_array(outputs[1], 2); // S
+        compute_encoder.set_output_array(outputs[2], 3); // Vt
+    } else {
+        compute_encoder.set_input_array(a_contig, 1);    // dummy
+        compute_encoder.set_output_array(outputs[0], 2); // S
+        compute_encoder.set_input_array(a_contig, 3);    // dummy
+    }
+
+    compute_encoder.set_bytes(params, sizeof(params), 4);
+    compute_encoder.set_bytes(&tol, sizeof(tol), 5);
+    compute_encoder.set_bytes(&max_sweeps, sizeof(max_sweeps), 6);
+
+    NSUInteger tg_size = std::min(
+        static_cast<NSUInteger>(256),
+        [pso maxTotalThreadsPerThreadgroup]);
+    compute_encoder.dispatch_threadgroups(
+        MTL::Size(num_matrices, 1, 1),
+        MTL::Size(tg_size, 1, 1));
+
+    // Sorting is done in the Metal kernel (in shared memory before writing).
+
+    d.add_temporary(std::move(a_contig), s.index);
+}
+
 } // namespace mlx::core
