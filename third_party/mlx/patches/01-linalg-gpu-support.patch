+++ b/mlx/backend/metal/linalg.mm
@@ -0,0 +1,79 @@
+// GPU implementation of Cholesky using Metal Performance Shaders.
+
+#include "mlx/backend/gpu/copy.h"
+#include "mlx/backend/metal/device.h"
+#include "mlx/primitives.h"
+
+#import <Metal/Metal.h>
+#import <MetalPerformanceShaders/MetalPerformanceShaders.h>
+
+namespace mlx::core {
+
+void Cholesky::eval_gpu(const std::vector<array>& inputs, array& out) {
+  const auto& a = inputs[0];
+
+  if (a.dtype() != float32) {
+    throw std::runtime_error(
+        "[Cholesky::eval_gpu] Only float32 is supported.");
+  }
+
+  // Copy input to output through the compute encoder.
+  copy_gpu(
+      a,
+      out,
+      a.flags().row_contiguous ? CopyType::Vector : CopyType::General);
+
+  int N = a.shape(-1);
+  if (N == 0) {
+    return;
+  }
+  size_t num_matrices = a.size() / (N * N);
+
+  auto& s = stream();
+  auto& d = metal::device(s.device);
+
+  // End the current compute encoder so we can encode MPS operations
+  // directly on the command buffer.
+  auto& enc = metal::get_command_encoder(s);
+  enc.end_encoding();
+  auto* cb = enc.get_command_buffer();
+  id<MTLCommandBuffer> cmd_buf =
+      (__bridge id<MTLCommandBuffer>)cb;
+  id<MTLDevice> mtl_dev =
+      (__bridge id<MTLDevice>)d.mtl_device();
+
+  BOOL lower = upper_ ? NO : YES;
+
+  for (size_t i = 0; i < num_matrices; i++) {
+    int64_t mat_offset = i * N * N;
+    id<MTLBuffer> buf =
+        (__bridge id<MTLBuffer>)(const_cast<void*>(out.buffer().ptr()));
+    size_t elem_size = out.itemsize();
+    size_t row_bytes = N * elem_size;
+    size_t byte_offset = (out.offset() + mat_offset) * elem_size;
+
+    MPSMatrixDescriptor* desc = [MPSMatrixDescriptor
+        matrixDescriptorWithRows:(NSUInteger)N
+                         columns:(NSUInteger)N
+                        rowBytes:row_bytes
+                        dataType:MPSDataTypeFloat32];
+
+    MPSMatrix* src_mat = [[MPSMatrix alloc] initWithBuffer:buf
+                                                    offset:byte_offset
+                                                descriptor:desc];
+    MPSMatrix* dst_mat = [[MPSMatrix alloc] initWithBuffer:buf
+                                                    offset:byte_offset
+                                                descriptor:desc];
+
+    MPSMatrixDecompositionCholesky* cholesky =
+        [[MPSMatrixDecompositionCholesky alloc] initWithDevice:mtl_dev
+                                                        lower:lower
+                                                        order:(NSUInteger)N];
+    [cholesky encodeToCommandBuffer:cmd_buf
+                       sourceMatrix:src_mat
+                       resultMatrix:dst_mat
+                             status:nil];
+  }
+}
+
+} // namespace mlx::core
